<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <title>@(ViewData["Title"] ?? "Admin Paneli")</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/AdminLTE-3.0.4/plugins/fontawesome-free/css/all.min.css" />
    <link rel="stylesheet" href="~/AdminLTE-3.0.4/dist/css/adminlte.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="hold-transition sidebar-mini layout-fixed">
    <div class="wrapper">
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
                </li>
            </ul>
        </nav>

        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <a asp-controller="Default" asp-action="Index" class="brand-link">
                <img src="~/AdminLTE-3.0.4/dist/img/AdminLTELogo.png" alt="AdminLTE Logo" class="brand-image img-circle elevation-3" style="opacity: .8" />
                <span class="brand-text font-weight-light">Siteye Git</span>
            </a>
            <div class="sidebar">
                <div class="user-panel mt-3 pb-3 mb-3 d-flex">
                    <div class="image">
                        <img src="https://i.hizliresim.com/163rypx.png" class="img-circle elevation-2" alt="Eray Güler" />
                    </div>
                    <div class="info"><a href="#" class="d-block">Eray Güler</a></div>
                </div>
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">
                        <li class="nav-item"><a href="/admin#profile" class="nav-link"><i class="nav-icon fas fa-user"></i><p>Hakkımda</p></a></li>
                        <li class="nav-item"><a href="/admin#education" class="nav-link"><i class="nav-icon fas fa-graduation-cap"></i><p>Eğitim</p></a></li>
                        <li class="nav-item"><a href="/admin#experience" class="nav-link"><i class="nav-icon fas fa-briefcase"></i><p>Deneyim</p></a></li>
                        <li class="nav-item"><a href="/admin#skills" class="nav-link"><i class="nav-icon fas fa-code"></i><p>Yetenekler</p></a></li>
                        <li class="nav-item"><a href="/admin#certificates" class="nav-link"><i class="nav-icon fas fa-award"></i><p>Sertifikalar</p></a></li>
                        <li class="nav-item"><a href="/admin#projects" class="nav-link"><i class="nav-icon fas fa-layer-group"></i><p>Projeler</p></a></li>
                        <li class="nav-item"><a href="/admin#social" class="nav-link"><i class="nav-icon fas fa-share-alt"></i><p>Sosyal Medya</p></a></li>
                        <li class="nav-item"><a href="/admin#blog" class="nav-link"><i class="nav-icon fas fa-newspaper"></i><p>Blog</p></a></li>
                        <li class="nav-item"><a href="/admin#messages" class="nav-link"><i class="nav-icon fas fa-envelope"></i><p>Mesajlar</p></a></li>
                        <li class="nav-item">
                            <a asp-controller="Default" asp-action="Index" class="nav-link">
                                <i class="nav-icon fas fa-external-link-alt"></i>
                                <p>Public Site</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Login" asp-action="LogOut" method="post" class="nav-link p-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-link nav-link text-left">
                                    <i class="nav-icon fas fa-sign-out-alt"></i>
                                    <span>Çıkış</span>
                                </button>
                            </form>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>

        <div class="content-wrapper">
            <section class="content pt-3">
                <div class="container-fluid">
                    @if (TempData["SuccessMessage"] is string successMessage)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @successMessage
                            <button type="button" class="close" data-dismiss="alert" aria-label="Kapat">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    }
                    @if (TempData["ErrorMessage"] is string errorMessage)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @errorMessage
                            <button type="button" class="close" data-dismiss="alert" aria-label="Kapat">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    }
                    @RenderBody()
                </div>
            </section>
        </div>
    </div>

    <script src="~/AdminLTE-3.0.4/plugins/jquery/jquery.min.js"></script>
    <script src="~/AdminLTE-3.0.4/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/AdminLTE-3.0.4/dist/js/adminlte.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
