@model LoginViewModel
@{
    Layout = null;
    var returnUrl = ViewData["ReturnUrl"] as string;
}
<!doctype html>
<html lang="tr">
<head>
    <title>Admin Giriş | Eray Güler</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <link rel="stylesheet" href="~/login-form-20/css/style.css" />
</head>
<body class="img js-fullheight" style="background-image: url(/login-form-20/images/bg.jpg);">
    <section class="ftco-section">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-md-6 text-center mb-5">
                    <h2 class="heading-section">Eray Güler Admin Paneli</h2>
                </div>
            </div>
            <div class="row justify-content-center">
                <div class="col-md-6 col-lg-4">
                    <div class="login-wrap p-0">
                        <h3 class="mb-4 text-center">Güvenli giriş</h3>
                        <form asp-controller="Login" asp-action="Index" asp-route-returnUrl="@returnUrl" method="post" class="signin-form">
                            @Html.AntiForgeryToken()
                            <div asp-validation-summary="ModelOnly" class="text-warning mb-3"></div>
                            <div class="form-group">
                                <input asp-for="UserName" class="form-control" placeholder="Kullanici adi" autocomplete="username" />
                                <span asp-validation-for="UserName" class="text-warning"></span>
                            </div>
                            <div class="form-group">
                                <input asp-for="Password" id="password-field" class="form-control" placeholder="Şifre" autocomplete="current-password" />
                                <span toggle="#password-field" class="fa fa-fw fa-eye field-icon toggle-password"></span>
                                <span asp-validation-for="Password" class="text-warning"></span>
                            </div>
                            <div class="form-group">
                                <button type="submit" class="form-control btn btn-primary submit px-3">Giriş Yap</button>
                            </div>
                            <div class="form-group d-md-flex">
                                <div class="w-100">
                                    <label class="checkbox-wrap checkbox-primary">
                                        Beni hatırla
                                        <input asp-for="RememberMe" />
                                        <span class="checkmark"></span>
                                    </label>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <script src="~/login-form-20/js/jquery.min.js"></script>
    <script src="~/login-form-20/js/popper.js"></script>
    <script src="~/login-form-20/js/bootstrap.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/login-form-20/js/main.js"></script>
</body>
</html>
